# CouponHubBot — local smoke-test secrets (gitignored)
# Copy to .env.local and fill in:
#   cp src/coupon-hub-bot/.env.local.example src/coupon-hub-bot/.env.local
# Then bring the stack up:
#   docker compose -f src/coupon-hub-bot/docker-compose.dev.yml --profile smoke up -d --build
#
# DATABASE_URL and ASPNETCORE_URLS are injected by docker-compose — do NOT set them here.

# --- Telegram (required) ---
# Token of the DUPLICATE test bot from @BotFather (NOT the production bot).
BOT_TELEGRAM_TOKEN=
# Any random secret. Telegram echoes this in X-Telegram-Bot-Api-Secret-Token
# on every webhook call; the bot rejects requests without it. Use the same
# value when calling setWebhook?secret_token=...
BOT_AUTH_TOKEN=
# Comma-separated Telegram user IDs allowed to use /feedback (your own user id is fine).
FEEDBACK_ADMINS=

# --- OCR (optional; leave blank to skip OCR — albums will still flow but no extraction) ---
AZURE_OCR_ENDPOINT=
AZURE_OCR_KEY=

# --- GitHub (optional; only needed by /feedback to file issues) ---
GITHUB_TOKEN=
GITHUB_REPO=Szer/coupon-bot

# --- Misc (optional) ---
COMMUNITY_CHAT_ID=
