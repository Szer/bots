# AlitaBot — local smoke-test secrets (gitignored)
# Copy to .env.local and fill in:
#   cp src/alita-bot/.env.local.example src/alita-bot/.env.local
# Then bring the stack up:
#   docker compose -f src/alita-bot/docker-compose.dev.yml --profile smoke up -d --build
#
# DATABASE_URL and ASPNETCORE_URLS are injected by docker-compose — do NOT set them here.

# --- Telegram (required) ---
# Token of the DEDICATED test bot from @BotFather (NOT a production bot).
BOT_TELEGRAM_TOKEN=
# Any random secret. Telegram echoes this in X-Telegram-Bot-Api-Secret-Token
# on every webhook call; the bot rejects requests without it. Use the same
# value when calling setWebhook?secret_token=...
BOT_AUTH_TOKEN=

# --- Azure AI Foundry (optional for RESPONDER_MODE=echo) ---
AZURE_FOUNDRY_KEY=

# --- Misc (optional; normally set via bot_setting) ---
TARGET_CHAT_IDS=
BOT_USERNAME=
