<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
    <!-- Custom entry point in Program.fs adds `login` / `list-dialogs` / `selfcheck` console modes. -->
    <XunitAutoGeneratedEntryPoint>false</XunitAutoGeneratedEntryPoint>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="RealEnv.fs" />
    <Compile Include="NgrokTunnel.fs" />
    <Compile Include="DevDb.fs" />
    <Compile Include="BotProcess.fs" />
    <Compile Include="Webhook.fs" />
    <Compile Include="TgUserClient.fs" />
    <Compile Include="SelfCheck.fs" />
    <Compile Include="RealAssemblyFixture.fs" />
    <Compile Include="SmokeTests.fs" />
    <!-- CompileAfter guarantees the [<EntryPoint>] file lands after build-injected
         sources (xunit runner reporters, MTP SelfRegisteredExtensions). -->
    <CompileAfter Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Dapper" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="Npgsql" />
    <PackageReference Include="WTelegramClient" />
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="xunit.runner.visualstudio" />
  </ItemGroup>

  <ItemGroup>
    <!-- Not used in code — referenced so `dotnet test tests/AlitaBot.RealTests -c Release`
         always (re)builds the bot the harness spawns from src/AlitaBot/bin/Release. -->
    <ProjectReference Include="..\..\src\AlitaBot\AlitaBot.fsproj" />
  </ItemGroup>

</Project>
