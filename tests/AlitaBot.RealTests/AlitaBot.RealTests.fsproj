<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
    <!-- Custom entry point in Program.fs adds `login` / `list-dialogs` / `selfcheck` console modes. -->
    <XunitAutoGeneratedEntryPoint>false</XunitAutoGeneratedEntryPoint>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="RealEnv.fs" />
    <Compile Include="GeminiProbe.fs" />
    <Compile Include="GeminiTransientDetection.fs" />
    <Compile Include="NgrokTunnel.fs" />
    <Compile Include="DevDb.fs" />
    <Compile Include="BotProcess.fs" />
    <Compile Include="Webhook.fs" />
    <Compile Include="TgUserClient.fs" />
    <Compile Include="DraftProbe.fs" />
    <Compile Include="SelfCheck.fs" />
    <Compile Include="RealAssemblyFixture.fs" />
    <Compile Include="TestRetry.fs" />
    <Compile Include="SmokeTests.fs" />
    <Compile Include="VoiceRealTests.fs" />
    <Compile Include="VisionRealTests.fs" />
    <Compile Include="ImageGenRealTests.fs" />
    <Compile Include="SongRealTests.fs" />
    <Compile Include="CommandRealTests.fs" />
    <Compile Include="AskRealTests.fs" />
    <Compile Include="DossierRealTests.fs" />
    <Compile Include="PersonaRealTests.fs" />
    <Compile Include="SocialRealTests.fs" />
    <Compile Include="ProactiveRealTests.fs" />
    <Compile Include="StretchRealTests.fs" />
    <!-- Runs LAST (real-test suites execute roughly in declaration order): its 2 extra
         real chat messages (image draw + web search ask) must not land in DossierRealTests'
         "last 24h" nightly-extraction window ahead of that test's own seeded facts — see
         NlToolLoopRealTests.fs's module doc comment for the empirical finding that prompted
         this placement. -->
    <Compile Include="NlToolLoopRealTests.fs" />
    <!-- CompileAfter guarantees the [<EntryPoint>] file lands after build-injected
         sources (xunit runner reporters, MTP SelfRegisteredExtensions). -->
    <CompileAfter Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Dapper" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="Npgsql" />
    <PackageReference Include="WTelegramClient" />
    <PackageReference Include="xunit.v3" />
    <PackageReference Include="xunit.runner.visualstudio" />
  </ItemGroup>

  <ItemGroup>
    <!-- Not used in code — referenced so `dotnet test tests/AlitaBot.RealTests -c Release`
         always (re)builds the bot the harness spawns from src/AlitaBot/bin/Release. -->
    <ProjectReference Include="..\..\src\AlitaBot\AlitaBot.fsproj" />
  </ItemGroup>

</Project>
